# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# Firebase service account keys (NEVER commit these)
*-firebase-adminsdk-*.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# large video files (host externally or use Git LFS)
public/media/trailers/
public/media/*.avi

# Steam store source assets — kept local, not needed for the website
public/brand/SteamworksAssets/

# Game build downloads (host on GitHub Releases instead)
public/Game/

# Loose source assets in Player Sprites folder (fonts, resumes, zips, extras)
public/media/Player Sprites/*.zip
public/media/Player Sprites/*.pdf
public/media/Player Sprites/DepartureMono-1.500/
public/media/Player Sprites/JetBrains_Mono/
public/media/Player Sprites/JetBrainsMono-2.304/


# superpowers brainstorm artifacts
.superpowers/
